# Backend Configuration
PORT=8000
FRONTEND_URL=http://localhost:5173
DATABASE_PATH=../database/scripts/cantik_ai.db

# Auth
JWT_SECRET=change-this-to-a-strong-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ADMIN_REQUIRE_BEARER=false
ADMIN_REQUIRE_CSRF=true
ADMIN_ENFORCE_ORIGIN=true
ADMIN_ORIGIN_STRICT=false
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=300000
ADMIN_LOGIN_RATE_LIMIT_MAX=20
ADMIN_LOGIN_BRUTE_WINDOW_MS=900000
ADMIN_LOGIN_BRUTE_MAX_FAILURES=5
ADMIN_LOGIN_LOCK_MS=900000

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Kiosk / Public Result Delivery
KIOSK_PUBLIC_BASE_URL=http://localhost:8000
KIOSK_RESULT_TOKEN_EXPIRES_DAYS=30
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=
