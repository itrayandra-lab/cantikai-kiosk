/*!40000 ALTER TABLE `chat_messages` DISABLE KEYS */;
INSERT INTO `chat_messages` VALUES (11,5,'user','Analisis Kulit Saya','2026-03-27 02:26:51'),(12,5,'assistant','Maaf, terjadi kesalahan saat memproses pesan Anda. Silakan coba lagi. 🌸','2026-03-27 02:26:54'),(13,6,'user','Tips Skincare Harian','2026-03-27 02:39:03'),(14,6,'assistant','**Tips Skincare Harian untuk Kulit yang Sehat dan Cerah** 🌸\n\nBerikut adalah beberapa tips skincare harian yang dapat membantu Anda mencapai kulit yang sehat dan cerah:\n\n### 1. **Bersihkan Muka dengan Baik**\n\n- Gunakan sabun muka yang sesuai dengan jenis kulit Anda.\n- Cuci muka dua kali sehari, pagi dan malam.\n- Pastikan untuk membersihkan area sekitar mata dan hidung dengan lembut.\n\n### 2. **Lumasi Kulit dengan Pelembab**\n\n- Gunakan pelembab yang sesuai dengan jenis kulit Anda.\n- Aplikasikan pelembab setelah membersihkan muka.\n- Pastikan untuk menyebar pelembab secara merata ke seluruh wajah.\n\n### 3. **Gunakan Sunscreen**\n\n- Gunakan sunscreen dengan SPF 30 atau lebih tinggi.\n- Aplikasikan sunscreen sebelum keluar rumah, terutama jika Anda akan berada di luar ruangan selama beberapa jam.\n- Pastikan untuk mengaplikasikan sunscreen secara merata ke seluruh wajah.\n\n### 4. **Tidur dengan Baik**\n\n- Pastikan untuk membersihkan muka sebelum tidur.\n- Gunakan masker wajah untuk membantu membersihkan pori-pori dan melembabkan kulit.\n- Tidur dengan posisi yang nyaman dan tidak terlalu panas.\n\n### 5. **Hindari Stres**\n\n- Stres dapat menyebabkan kulit menjadi kusam dan berminyak.\n- Coba untuk mengurangi stres dengan melakukan aktivitas yang menyenangkan, seperti berjalan kaki atau meditasi.\n\nDengan mengikuti tips skincare harian di atas, Anda dapat membantu mencapai kulit yang sehat dan cerah. Jangan lupa untuk selalu mengikuti rekomendasi dari dokter atau ahli kulit jika Anda memiliki masalah kulit yang serius.','2026-03-27 02:39:05'),(15,7,'user','Analisis Kulit Saya','2026-03-27 02:39:17'),(16,7,'assistant','**Halo! Saya siap membantu Anda** 🌸\n\nUntuk melakukan analisis kulit Anda, saya perlu tahu beberapa informasi tentang kondisi kulit Anda. Silakan menjawab pertanyaan-pertanyaan berikut:\n\n1. Apa jenis kulit Anda? (Pilih salah satu):\n - Kulit normal\n - Kulit berminyak\n - Kulit kering\n - Kulit kombinasi\n - Kulit sensitif\n2. Apakah Anda memiliki masalah kulit seperti jerawat, flek hitam, atau kulit kusam?\n3. Apakah Anda menggunakan produk skincare dan jika ya, apa jenis produk yang Anda gunakan?\n4. Apakah Anda memiliki kebiasaan perawatan kulit harian, seperti membersihkan wajah secara teratur?\n\nSetelah saya menerima informasi Anda, saya dapat melakukan analisis kulit Anda dan memberikan rekomendasi yang sesuai.','2026-03-27 02:39:18'),(17,8,'user','Analisis Kulit Saya','2026-03-27 03:34:15'),(18,8,'assistant','**Selamat datang! 🌸**\n\nUntuk melakukan analisis kulit, saya perlu beberapa informasi tentang kondisi kulit Anda. Silakan jawab pertanyaan-pertanyaan berikut:\n\n1. Apa jenis kulit Anda? (Pilih salah satu)\n * Kulit normal\n * Kulit berminyak\n * Kulit kering\n * Kulit kombinasi\n2. Apakah Anda memiliki masalah kulit seperti jerawat, komedo, atau flek hitam?\n3. Apakah Anda menggunakan produk skincare apa saja sekarang?\n4. Apakah Anda memiliki kebiasaan perawatan kulit harian seperti membersihkan wajah secara teratur atau menggunakan tabir surya?\n\nSetelah Anda menjawab pertanyaan-pertanyaan di atas, saya dapat melakukan analisis kulit Anda dan memberikan rekomendasi produk skincare dan tips perawatan kulit yang sesuai dengan kebutuhan Anda.','2026-03-27 03:34:17'),(19,9,'user','Routine Skincare','2026-03-27 04:48:48'),(20,9,'assistant','**Perawatan Kulit yang Tepat** 🌸\n\nBerikut adalah langkah-langkah dasar untuk membuat routine skincare yang efektif:\n\n1. **Membersihkan Kulit** 💦\n - Gunakan sabun muka yang sesuai dengan jenis kulit Anda.\n - Cuci wajah dengan air hangat setiap pagi dan malam hari.\n2. **Mengeringkan Kulit** 💨\n - Gunakan kanebo atau produk pengeringan kulit yang lembut.\n - Biarkan kulit Anda mengering secara alami.\n3. **Menggunakan Toner** 💧\n - Gunakan toner yang dapat membantu menyeimbangkan pH kulit.\n - Biarkan toner meresap ke dalam kulit sebelum melanjutkan ke langkah berikutnya.\n4. **Menggunakan Serum** 💊\n - Pilih serum yang sesuai dengan kebutuhan kulit Anda (misalnya anti-penuaan, anti-acne, atau anti-kerutan).\n - Aplikasikan serum ke kulit dengan menggunakan jari atau aplikator.\n5. **Menggunakan Krim** 💄\n - Pilih krim yang sesuai dengan jenis kulit Anda (misalnya krim yang ringan untuk kulit sensitif atau krim yang pekat untuk kulit yang kering).\n - Aplikasikan krim ke kulit dengan menggunakan jari atau aplikator.\n6. **Menggunakan Sunscreen** ☀️\n - Gunakan sunscreen dengan SPF minimal 30 untuk melindungi kulit dari sinar UV.\n - Aplikasikan sunscreen ke kulit dengan menggunakan jari atau aplikator.\n\n**Tips**:\n\n- Pastikan untuk menggunakan produk skincare yang sesuai dengan jenis kulit Anda.\n- Jangan menggunakan produk skincare yang sama untuk wajah dan tubuh.\n- Istirahatlah dan jangan lupa untuk minum air yang cukup untuk menjaga kulit Anda tetap sehat!','2026-03-27 04:48:50'),(21,10,'user','Analisis Kulit Saya','2026-03-27 07:01:47'),(22,10,'assistant','**Analisis Kulit Saya** 🌸\n\nUntuk melakukan analisis kulit, saya perlu beberapa informasi dari Anda. Silakan jawab pertanyaan-pertanyaan berikut:\n\n1. Apa jenis kulit Anda (normal, berminyak, kering, kombinasi)?\n2. Apakah Anda memiliki masalah kulit seperti jerawat, flek hitam, atau kulit berpigmen?\n3. Apakah Anda memiliki kebiasaan skincare rutin (bersihkan wajah, pakai pelembab, dll.)?\n4. Apakah Anda menggunakan produk skincare tertentu yang membuat kulit Anda menjadi lebih baik atau lebih buruk?\n\nDengan informasi ini, saya dapat melakukan analisis kulit dan memberikan rekomendasi yang tepat untuk Anda! 🌸','2026-03-27 07:01:49'),(23,11,'user','Analisis Kulit Saya','2026-03-28 02:24:43'),(24,11,'assistant','Halo! 🌸 Saya senang membantu Anda menganalisis kondisi kulit Anda. Untuk melakukan analisis ini, saya perlu beberapa informasi tentang kulit Anda. Silakan menjawab pertanyaan-pertanyaan berikut:\n\n1. Apa jenis kulit Anda? (Pilih salah satu: Berminyak, Kering, Normal, Berjerawat)\n2. Apakah kulit Anda memiliki masalah seperti jerawat, flek hitam, atau pigmentasi?\n3. Apakah Anda memiliki kebiasaan tertentu yang dapat mempengaruhi kondisi kulit Anda (seperti menggunakan produk skincare yang tidak tepat, tidak terbiasa menggunakan sunblock, atau memiliki stres)?\n4. Apa tujuan Anda dalam menjaga kulit (seperti ingin menghilangkan jerawat, mengencangkan kulit, atau meningkatkan kelembaban kulit)?\n\nSetelah saya menerima jawaban Anda, saya akan memberikan analisis kondisi kulit Anda dan rekomendasi perawatan kulit yang tepat! 🌸','2026-03-28 02:24:44'),(25,12,'user','Apa saja layanan dan keahlian khusus yang dimiliki Dr. Marilyn Stanton?','2026-03-28 02:42:24'),(26,12,'assistant','Saya tidak menemukan informasi tentang Dr. Marilyn Stanton. Namun, saya dapat memberikan informasi tentang keahlian saya sebagai Cantik AI, asisten dermatologi pribadi yang ramah dan profesional.\n\n**Layanan dan Keahlian Khusus:**\n\n1. **Analisis Kondisi Kulit**: Saya dapat menganalisis kondisi kulit Anda dan memberikan rekomendasi perawatan yang tepat.\n2. **Rekomendasi Produk Skincare**: Saya dapat merekomendasikan produk skincare yang sesuai dengan kebutuhan kulit Anda.\n3. **Tips Perawatan Kulit Harian**: Saya dapat memberikan tips perawatan kulit harian yang efektif dan mudah diikuti.\n4. **Menjawab Pertanyaan tentang Skincare**: Saya dapat menjawab pertanyaan-pertanyaan tentang skincare dan kulit Anda.\n\n**Keahlian Khusus:**\n\n- Mengenal kondisi kulit yang umum, seperti jerawat, kulit kering, kulit berminyak, dan lain-lain.\n- Mengenal jenis kulit dan kebutuhan perawatan yang spesifik.\n- Merekomendasikan produk skincare yang aman dan efektif.\n- Memberikan tips perawatan kulit yang mudah diikuti dan efektif.\n\nJika Anda memiliki pertanyaan atau kebutuhan perawatan kulit, saya siap membantu! 🌸','2026-03-28 02:42:25'),(27,13,'user','Saya punya masalah kulit [jelaskan masalah], apakah Dr. Marilyn Stanton bisa membantu?','2026-03-28 02:42:51'),(28,13,'assistant','Maaf, saya tidak menemukan informasi tentang Dr. Marilyn Stanton. Namun, saya, Cantik AI, dapat membantu Anda dengan masalah kulit Anda! 🌸\n\nUntuk memulai, silakan jelaskan masalah kulit Anda secara spesifik, seperti:\n\n- Kulit kering?\n- Kulit berminyak?\n- Jerawat?\n- Flek hitam?\n- Kulit berwarna tidak merata?\n- Masalah lainnya?\n\nSaya akan berusaha membantu Anda dengan rekomendasi produk skincare, tips perawatan kulit, dan saran lainnya untuk membantu Anda mencapai kulit yang sehat dan cantik!','2026-03-28 02:42:52'),(29,14,'user','Apa saja layanan dan keahlian khusus yang dimiliki Dr. Marilyn Stanton?','2026-03-28 04:18:14'),(30,14,'assistant','Dr. Marilyn Stanton adalah seorang General Physician yang berpengalaman selama 10 tahun dalam memberikan layanan kesehatan yang komprehensif kepada pasien. Berikut adalah beberapa layanan dan keahlian khusus yang dimiliki oleh Dr. Marilyn Stanton:\n\n**Layanan Umum**\n\n* Pemeriksaan kesehatan secara keseluruhan\n* Diagnosis dan pengobatan penyakit umum\n* Konsultasi tentang nutrisi dan gaya hidup sehat\n* Pemeriksaan laboratorium dan radiologi\n\n**Keahlian Khusus**\n\n* **Kesehatan Kulit**: Dr. Marilyn Stanton memiliki keahlian khusus dalam kesehatan kulit, termasuk diagnosis dan pengobatan penyakit kulit seperti kulit berminyak, kulit kering, jerawat, dan lain-lain.\n* **Perawatan Preventif**: Dr. Marilyn Stanton juga memiliki keahlian dalam memberikan saran dan rekomendasi tentang cara menjaga kesehatan dan mencegah penyakit dengan cara yang aman dan efektif.\n* **Nutrisi**: Dr. Marilyn Stanton memiliki pengetahuan yang luas tentang nutrisi dan dapat memberikan saran tentang cara menjaga kesehatan melalui makanan yang seimbang.\n\n**Layanan Lain**\n\n* Konsultasi online dan offline\n* Pemeriksaan kesehatan di rumah atau di klinik\n* Saran dan rekomendasi tentang cara menjaga kesehatan dan mencegah penyakit\n\nJika Anda memiliki pertanyaan atau kekhawatiran tentang kesehatan Anda, silakan booking konsultasi dengan Dr. Marilyn Stanton untuk informasi lebih detail.','2026-03-28 04:18:15'),(31,15,'user','Analisis Kulit Saya','2026-03-28 04:21:44'),(32,15,'assistant','Selamat datang di Cantik AI 🌸! Saya senang membantu Anda melakukan analisis kulit. Untuk memulai, saya perlu beberapa informasi tentang kondisi kulit Anda. Silakan jawab pertanyaan-pertanyaan berikut:\n\n1. **Apa jenis kulit Anda?** 🤔\n * Kulit normal\n * Kulit berminyak\n * Kulit kering\n * Kulit kombinasi\n2. **Apa masalah kulit yang Anda alami?** 🤕\n * Jerawat\n * Kulit berjerawat\n * Kulit kusam\n * Kulit sensitif\n3. **Apa produk skincare yang Anda gunakan?** 🛍️\n * Nama produk\n * Jenis produk (mengandung apa?)\n4. **Bagaimana Anda merawat kulit Anda?** 💆‍♀️\n * Apakah Anda melakukan rutinitas skincare harian?\n * Apakah Anda menggunakan produk skincare yang sesuai dengan jenis kulit Anda?\n\nDengan informasi ini, saya dapat membantu Anda melakukan analisis kulit dan memberikan rekomendasi yang tepat untuk perawatan kulit Anda.','2026-03-28 04:21:44'),(33,16,'user','Kulit saya kusam dan tidak bercahaya, padahal sudah pakai skincare','2026-03-28 05:23:54'),(34,16,'assistant','**Konsultasi Medis dengan Dr. Marilyn Stanton**\n\nSelamat datang! Saya senang bisa membantu Anda dengan masalah kulit kusam dan tidak bercahaya. Saya tahu bahwa sudah menggunakan skincare bisa membantu, tapi mungkin ada beberapa hal lain yang perlu kita perhatikan.\n\n**Gejala dan Detail**\nAnda mengatakan bahwa kulit Anda kusam dan tidak bercahaya. Apakah Anda merasakan kulit Anda menjadi lebih kering atau iritasi? Apakah ada perubahan lain pada kulit Anda, seperti jerawat atau bintik-bintik?\n\n**Diagnosis Awal**\nDari gejala yang Anda deskripsikan, saya curiga bahwa mungkin ada beberapa penyebab kulit kusam dan tidak bercahaya. Salah satu kemungkinan adalah karena kurangnya nutrisi pada kulit, seperti kekurangan vitamin C atau E. Atau mungkin kulit Anda terpapar sinar UV yang berlebihan.\n\n**Penyebab dan Kondisi**\nKulit kusam dan tidak bercahaya bisa disebabkan oleh beberapa faktor, seperti:\n* Kurangnya nutrisi pada kulit\n* Terpapar sinar UV yang berlebihan\n* Penggunaan produk skincare yang tidak sesuai dengan jenis kulit Anda\n* Stres atau kelelahan\n\n**Treatment dan Perawatan**\nUntuk mengatasi kulit kusam dan tidak bercahaya, saya merekomendasikan beberapa hal:\n* Gunakan produk skincare yang sesuai dengan jenis kulit Anda\n* Pastikan Anda menggunakan tabir surya dengan SPF yang tinggi untuk melindungi kulit dari sinar UV\n* Konsumsi makanan yang kaya akan nutrisi, seperti buah-buahan dan sayuran\n* Coba untuk mengurangi stres dan kelelahan dengan melakukan aktivitas yang menyenangkan\n\n**Tips Preventif**\nUntuk mencegah kulit kusam dan tidak bercahaya di masa depan, saya merekomendasikan:\n* Gunakan produk skincare yang sesuai dengan jenis kulit Anda\n* Pastikan Anda menggunakan tabir surya dengan SPF yang tinggi\n* Konsumsi makanan yang kaya akan nutrisi\n* Coba untuk mengurangi stres dan kelelahan\n\n**Konsultasi Tatap Muka**\nJika Anda merasa perlu pemeriksaan fisik lebih lanjut, saya ajak Anda booking konsultasi tatap muka. Saya akan melakukan pemeriksaan fisik dan memberikan rekomendasi yang lebih spesifik untuk kulit Anda.\n\nBagaimana? Apakah Anda memiliki pertanyaan atau ingin mencoba rekomend','2026-03-28 05:23:56'),(35,17,'user','Jerawat saya selalu muncul saat stress atau kurang tidur','2026-03-28 05:40:05'),(36,17,'assistant','**Jerawat dan Stres**\n======================\n\nSaya mengerti bahwa jerawat dapat menjadi masalah yang sangat mengganggu, terutama ketika ia muncul secara tidak terduga. Saya ingin memahami lebih lanjut tentang gejala jerawat Anda.\n\n**Gejala Jerawat Anda**\n------------------------\n\nSilakan menjelaskan lebih lanjut tentang jerawat Anda, seperti:\n\n* Apakah jerawat Anda berwarna merah atau berwarna putih?\n* Apakah jerawat Anda berbentuk seperti komedo, nodul, atau papula?\n* Berapa lama jerawat Anda muncul dan berapa lama ia hilang?\n* Apakah Anda memiliki riwayat jerawat sebelumnya?\n\n**Hubungan Stres dengan Jerawat**\n---------------------------------\n\nSaya ingin mengetahui lebih lanjut tentang hubungan antara stres dan jerawat Anda. Apakah Anda memiliki riwayat stres yang tinggi, seperti:\n\n* Apakah Anda memiliki pekerjaan yang sangat menekan?\n* Apakah Anda memiliki masalah hubungan yang sulit?\n* Apakah Anda memiliki kecemasan yang tinggi?\n\n**Konsultasi Selanjutnya**\n---------------------------\n\nSetelah saya mendengar lebih lanjut tentang gejala jerawat Anda dan hubungan stres dengan jerawat, saya akan dapat memberikan diagnosis awal dan rekomendasi perawatan yang tepat.\n\nSaya ingin menyarankan Anda untuk booking konsultasi tatap muka agar saya dapat melakukan pemeriksaan fisik yang lebih lanjut dan memberikan diagnosis yang lebih akurat. Apakah Anda memiliki waktu untuk booking konsultasi tatap muka?','2026-03-28 05:40:07'),(37,18,'user','Kulit saya sensitif dan mudah iritasi, apa penyebabnya?','2026-03-28 06:05:43'),(38,18,'assistant','**Saya senang membantu Anda menjelajahi masalah kulit sensitif dan iritasi!**\n\nSaya paham bahwa kulit sensitif dan mudah iritasi dapat sangat mengganggu kenyamanan dan kepercayaan diri Anda. Berikut beberapa kemungkinan penyebab kulit Anda menjadi sensitif dan mudah iritasi:\n\n### 1. **Kerusakan kulit alami**\nKulit Anda mungkin telah mengalami kerusakan karena faktor alami seperti usia, lingkungan, atau genetik. Hal ini dapat menyebabkan kulit Anda menjadi lebih sensitif dan mudah iritasi.\n\n### 2. **Kulit yang terpapar sinar UV**\nTerlalu banyak paparan sinar UV dari matahari dapat menyebabkan kulit Anda menjadi sensitif dan mudah iritasi. Sinar UV dapat merusak kulit dan membuatnya menjadi lebih rentan terhadap iritasi.\n\n### 3. **Kulit yang terpapar bahan kimia**\nKulit Anda mungkin telah terpapar bahan kimia seperti pewarna, bahan pembersih, atau produk perawatan kulit yang tidak sesuai dengan jenis kulit Anda. Hal ini dapat menyebabkan kulit Anda menjadi sensitif dan mudah iritasi.\n\n### 4. **Kulit yang terinfeksi**\nKulit Anda mungkin telah terinfeksi oleh bakteri, virus, atau jamur. Hal ini dapat menyebabkan kulit Anda menjadi sensitif dan mudah iritasi.\n\n### 5. **Kulit yang tidak seimbang**\nKulit Anda mungkin tidak seimbang, artinya memiliki pH yang tidak sesuai dengan jenis kulit Anda. Hal ini dapat menyebabkan kulit Anda menjadi sensitif dan mudah iritasi.\n\n**Untuk mengatasi masalah kulit sensitif dan mudah iritasi, saya sarankan Anda melakukan beberapa hal berikut:**\n\n* **Gunakan produk perawatan kulit yang sesuai dengan jenis kulit Anda**\n* **Hindari paparan sinar UV**\n* **Gunakan bahan kimia yang aman dan alami**\n* **Jaga kebersihan kulit Anda**\n* **Makan makanan yang seimbang dan kaya akan nutrisi**\n\n**Jika masalah kulit Anda tidak kunjung membaik, saya sarankan Anda booking konsultasi tatap muka dengan saya untuk melakukan pemeriksaan fisik lebih lanjut dan menentukan penyebab yang lebih spesifik.**\n\nSaya harap informasi ini membantu Anda menjelajahi masalah kulit sensitif dan mudah iritasi. Jika','2026-03-28 06:05:44');
/*!40000 ALTER TABLE `chat_messages` ENABLE KEYS */;
UNLOCK TABLES;

--
-- Table structure for table `chat_sessions`
--

DROP TABLE IF EXISTS `chat_sessions`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `chat_sessions` (
  `id` int NOT NULL AUTO_INCREMENT,
  `user_id` int NOT NULL,
  `title` varchar(255) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT 'New Chat',
  `session_uuid` varchar(255) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  `updated_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  UNIQUE KEY `session_uuid` (`session_uuid`),
  KEY `idx_chat_sessions_user_id` (`user_id`),
  KEY `idx_chat_sessions_uuid` (`session_uuid`),
  CONSTRAINT `chat_sessions_ibfk_1` FOREIGN KEY (`user_id`) REFERENCES `users` (`id`) ON DELETE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=19 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `chat_sessions`
--

LOCK TABLES `chat_sessions` WRITE;
/*!40000 ALTER TABLE `chat_sessions` DISABLE KEYS */;
