  `updated_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  UNIQUE KEY `slug` (`slug`),
  KEY `idx_articles_slug` (`slug`),
  KEY `idx_articles_category` (`category`),
  KEY `idx_articles_status` (`status`),
