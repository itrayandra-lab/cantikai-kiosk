INSERT INTO `analyses` VALUES (9,4,'uploads/assets/4_original_1774579387320.png','',75.00,'combination','III',25,'6.1-with-beautylatory-products','Gemini 2.5 Flash (Vision) + Groq GPT-OSS-20B (Text) + Beautylatory Products',11140,'{}','{\"acne\": {\"severity\": \"ringan\", \"acne_count\": 0, \"acne_score\": 20}, \"engine\": \"Gemini 2.5 Flash (Vision) + Groq GPT-OSS-20B (Text) + Beautylatory Products\", \"oiliness\": {\"sebum_level\": \"sedang\", \"oiliness_score\": 50}, \"ai_report\": {\"summary\": \"Kulit kombinasi dengan keseimbangan sedang, hidrasi baik, namun masih ada ketidakseimbangan minyak di area T-zone. Skor keseluruhan 75 menunjukkan kondisi kulit cukup sehat namun perlu perhatian pada pencegahan jerawat ringan dan perlindungan dari polusi.\", \"main_concerns\": [\"Kelebihan minyak di T-zone\", \"Keseimbangan hidrasi\", \"Perlindungan dari polusi dan sinar UV\"], \"recommendations\": {\"lifestyle_tips\": [\"Minum cukup air\", \"Hindari makanan berminyak tinggi\"], \"long_term_goals\": [\"Meningkatkan barrier kulit\", \"Mengurangi frekuensi jerawat ringan\"], \"immediate_actions\": [\"Gunakan pembersih ringan dua kali sehari\", \"Tambahkan serum niacinamide untuk mengontrol minyak\"]}, \"skincare_routine\": {\"evening\": [\"Cuci wajah dengan ADHWA Serenity Facial Cleanser\", \"Terapkan BEAUTYLATORY Urban Shield Serum\", \"Semprot ADHWA Serenity Radiance Face Mist\"], \"morning\": [\"Cuci wajah dengan ADHWA Serenity Facial Cleanser\", \"Terapkan BEAUTYLATORY Urban Shield Serum\", \"Semprot ADHWA Serenity Radiance Face Mist\", \"Gunakan tabir surya jika diperlukan\"]}, \"skin_type_analysis\": \"Kulit kombinasi berarti bagian wajah (T-zone) cenderung berminyak, sementara dahi dan pipi lebih kering. Hidrasi 65% menunjukkan kulit cukup lembap, namun area berminyak memerlukan produk ringan yang tidak menambah minyak.\", \"product_recommendations\": [{\"name\": \"ADHWA - Serenity Facial Cleanser 30 ml\", \"slug\": \"adhwa-serenity-facial-cleanser-30-ml\", \"reas